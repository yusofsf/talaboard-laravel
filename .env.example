APP_NAME="آبشده صفرپور"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=fa

LOG_CHANNEL=single
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/shop.db

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# ادمین اصلی (اولین ورود با این شماره، ادمین می‌شود)
ADMIN_PHONE=09xxxxxxxxx

# کاوه‌نگار پیامک (اختیاری)
KAVENEGAR_API_KEY=
KAVENEGAR_SENDER=
KAVENEGAR_OTP_TEMPLATE=verify
KAVENEGAR_RESET_TEMPLATE=
TWO_FA_ENABLED=false

# کد تأیید پشتیبان — وقتی پیامک نمی‌رسد با این کد می‌توان تأیید کرد
# برای غیرفعال‌کردن، خالی بگذارید
MASTER_OTP=000000

# تالالند — قیمت طلا
TALALAND_API_BASE=https://api.talaland.net/api
TALALAND_USERNAME=your-reseller-id
TALALAND_TOKEN=your-api-key
MITHQAL_GRAMS=4.3318
# درصد اختلاف خرید/فروش از قیمت میانی برای طلا و نقره (مثلاً 0.01 = 1%)
# فروش = میانی × (1+GOLD_FACTOR)   |   خرید = میانی × (1-GOLD_FACTOR)
GOLD_FACTOR=0

# دلار (آلان‌چند)
DOLLAR_HOME_URL=https://alanchand.com/

# انس طلا — اول Yahoo Finance (GC=F)، در صورت خطا آلان‌چند به‌عنوان fallback
GOLD_OUNCE_SYMBOL=GC=F
DOLLAR_GOLD_URL=https://alanchand.com/gold-price

# دیتابیس ربات نقره (sachmebot_laravel) — فقط خواندنی
SILVER_DB_PATH=/home/USERNAME/sachmebot_laravel/database/database.sqlite

# shop.db نسخه‌ی قبلی Flask — فقط برای دستور import:flask-shop (یک‌بار مصرف)
FLASK_SHOP_DB_PATH=/home/USERNAME/talaboard/shop.db

# مدت کش قیمت (ثانیه)
CACHE_TTL=30

# تعداد ثانیه بین رفرش‌های تابلوی قیمت در مرورگر
REFRESH_SECONDS=30
